# Grafana Cloud — OTLP gateway (single endpoint for traces, metrics, logs)
GCLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-3.grafana.net/otlp
GCLOUD_INSTANCE_ID=123456
GCLOUD_RW_API_KEY=glc_xxx

# Pyroscope — find under your stack → Profiles → Send Data
GCLOUD_HOSTED_PYROSCOPE_URL=https://profiles-prod-004.grafana.net
GCLOUD_HOSTED_PYROSCOPE_ID=123456

# GitHub (for Grafana Assistant MCP — used in Grafana Cloud UI, not by containers)
GITHUB_PAT=ghp_xxx
